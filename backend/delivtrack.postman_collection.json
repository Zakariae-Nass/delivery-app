{
  "info": {
    "name": "DelivTrack API",
    "description": "Complete API collection for DelivTrack — NestJS authentication system with profile completion flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "adminSecret", "value": "super-secret-admin-key-12345", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Delivery",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register/delivery",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"new_driver\",\n  \"email\": \"newdriver@example.com\",\n  \"password\": \"Password1\",\n  \"phone\": \"+21655001234\"\n}"
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Secret", "value": "{{adminSecret}}" }
            ],
            "url": "{{baseUrl}}/auth/register/admin",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"new_admin\",\n  \"email\": \"newadmin@example.com\",\n  \"password\": \"Admin1234\",\n  \"phone\": \"+21698001234\"\n}"
            }
          }
        },
        {
          "name": "Register Agency",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register/agency",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"new_agency\",\n  \"email\": \"newagency@example.com\",\n  \"password\": \"Agency123\",\n  \"phone\": \"+21671001234\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('accessToken', json.access_token);",
                  "  pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ali@delivtrack.com\",\n  \"password\": \"Driver123\"\n}"
            }
          }
        },
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('accessToken', json.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@delivtrack.com\",\n  \"password\": \"Admin1234\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/auth/logout"
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Update Location",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/users/location",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Tunis, Tunisia\",\n  \"lat\": 36.8065,\n  \"lng\": 10.1815\n}"
            }
          }
        },
        {
          "name": "Get Profile Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/users/profile-status"
          }
        }
      ]
    },
    {
      "name": "Delivery",
      "item": [
        {
          "name": "Update Delivery Profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/delivery/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rate\": 4.5,\n  \"vehicleType\": \"motorcycle\"\n}"
            }
          }
        },
        {
          "name": "Upload Documents",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/delivery/documents",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "cin", "value": "12345678", "type": "text" },
                { "key": "licence", "value": "A-001122", "type": "text" },
                { "key": "cinImage", "type": "file", "src": "" },
                { "key": "licenceImage", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Get Documents",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/delivery/documents"
          }
        },
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/delivery/dashboard"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Deliveries",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/deliveries?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Delivery By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/admin/deliveries/1"
          }
        },
        {
          "name": "Approve Documents",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/admin/verify/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\"\n}"
            }
          }
        },
        {
          "name": "Reject Documents",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/admin/verify/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"rejected\",\n  \"reason\": \"CIN image is not clear\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Agency",
      "item": [
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/agency/dashboard"
          }
        }
      ]
    }
  ]
}
